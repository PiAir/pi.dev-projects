# Copy this file to .env and fill in your values.
#
# Windows (PowerShell) — load into current session:
#   Get-Content .env | Where-Object { $_ -notmatch '^#' -and $_ -match '=' } | ForEach-Object { $k,$v = $_ -split '=',2; [System.Environment]::SetEnvironmentVariable($k.Trim(), $v.Trim()) }
#
# Linux / WSL2 (bash):
#   source .env   (or use direnv)

# ── Required ───────────────────────────────────────────────────────────────────

# Full path to your Zotero profile directory.
# Find it in Zotero under: Edit → Settings → Advanced → "Open profile directory"
#
# Windows:
ZOTERO_PROFILE_DIR=C:\Users\your-name\AppData\Roaming\Zotero\Zotero\Profiles\xxxxxxxx.default
# WSL2:
# ZOTERO_PROFILE_DIR=/mnt/c/Users/your-name/AppData/Roaming/Zotero/Zotero/Profiles/xxxxxxxx.default

# Full path to your Zotero data directory (contains zotero.sqlite, storage/, etc.)
# Find it in Zotero under: Edit → Settings → Advanced → "Data Directory Location"
#
# Windows:
ZOTERO_DATA_DIR=C:\Users\your-name\Zotero
# WSL2:
# ZOTERO_DATA_DIR=/mnt/c/Users/your-name/Zotero

# ── Optional ───────────────────────────────────────────────────────────────────

# Zotero Local API base URL — only change if Zotero runs on a non-default port
# ZOTERO_LOCAL_API=http://localhost:23119

# Base path for PDF attachments stored outside the Zotero data directory
# (e.g. on a NAS or external drive via SynologyDrive)
# Windows:
# ZOTERO_PDF_BASE=C:\SynologyDrive\zotero-bijlagen
# WSL2:
# ZOTERO_PDF_BASE=/mnt/c/SynologyDrive/zotero-bijlagen

# Working directory where pdfs/ and markdown/ cache folders are created
# Defaults to the current directory if not set
# Windows:
# WORK_DIR=C:\path\to\your\working\directory
# WSL2:
# WORK_DIR=/mnt/c/path/to/your/working/directory

# Python executable to use when the script calls convert_to_md.py as a subprocess.
# Only set this if 'python' / 'python3' is not found automatically (e.g. in some
# OpenCode environments). Use sys.executable as ultimate fallback if left unset.
# Windows example:
# PYTHON_CMD=C:\Program Files\Python313\python.exe
# WSL2 / Linux example:
# PYTHON_CMD=/usr/bin/python3

# Full path to the Tesseract executable — only needed for scanned/image-heavy PDFs.
# On Windows the default install path is found automatically.
# On WSL2/Linux, 'tesseract' on PATH is used automatically.
# Only set this if Tesseract is installed in a non-standard location.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
